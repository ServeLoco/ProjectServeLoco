PORT=3000
NODE_ENV=development
# Generate a strong JWT secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
ADMIN_OWNER_ID=your_admin_id_here
# Generate a bcrypt hash for the password using: node -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_here
ADMIN_PASSWORD=your_admin_password_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=serveloco
MYSQL_USER=root
MYSQL_PASSWORD=root
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=serveloco_images
# Comma-separated list of allowed origins. In production, do not use '*'!
CORS_ORIGIN=*
PUBLIC_BASE_URL=http://10.0.2.2:3000
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
STATIC_UPLOAD_PATH=/uploads
