APP_ENV=proddb
NODE_ENV=development
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=30d

ADMIN_OWNER_ID=you@example.com
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
ADMIN_JWT_EXPIRES_IN=12h
# ADMIN_PASSWORD=replace_with_your_plaintext_password   # dev/test fallback only

# ── Azure MySQL (Flexible Server, centralindia) ───────────────────────
MYSQL_HOST=your-server.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=serveloco
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_SSL=true
MYSQL_SSL_CA_PATH=

# ── MongoDB Atlas (image metadata) ────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=serveloco_images

# ── CORS + public URLs (local UIs only) ───────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
PUBLIC_BASE_URL=http://localhost:3000

# ── Image storage: S3 (production data lives here) ────────────────────
STORAGE_DRIVER=s3
S3_BUCKET=villkro-images-prod
S3_REGION=ap-south-1
S3_PUBLIC_URL=https://villkro-images-prod.s3.ap-south-1.amazonaws.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy disk-upload settings (unused when STORAGE_DRIVER=s3)
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
STATIC_UPLOAD_PATH=/uploads

# Never auto-seed against production DBs
SKIP_SEED_DEFAULTS=true

# Pool + logging (optional)
MYSQL_POOL_SIZE=30
LOG_LEVEL=info
