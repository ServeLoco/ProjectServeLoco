APP_ENV=production
NODE_ENV=production
PORT=3000

JWT_SECRET=use_render_generated_or_a_strong_secret
JWT_EXPIRES_IN=1d

ADMIN_OWNER_ID=your_admin_owner_id
ADMIN_PASSWORD_HASH=your_bcrypt_admin_password_hash

MYSQL_HOST=servelocoserver.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=serveloco
MYSQL_USER=servelocoadmin
MYSQL_PASSWORD=your_azure_mysql_password
MYSQL_SSL=true
MYSQL_SSL_CA_PATH=

MONGODB_URI=your_mongodb_atlas_uri
MONGODB_DATABASE=serveloco_images

CORS_ORIGIN=https://your-admin-domain.example
PUBLIC_BASE_URL=https://serveloco-backend.onrender.com
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
STATIC_UPLOAD_PATH=/uploads
