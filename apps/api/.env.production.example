APP_ENV=production
NODE_ENV=production
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=1d

# Admin login. ADMIN_PASSWORD (plaintext) is the supported path; the .env.production
# file is gitignored + only readable on the server. ADMIN_PASSWORD_HASH is
# still accepted as a fallback if you already generated one.
ADMIN_OWNER_ID=you@example.com
ADMIN_PASSWORD=replace_with_your_plaintext_password
# ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash   # (optional fallback)

# ── Azure MySQL (Flexible Server, centralindia) ───────────────────────
MYSQL_HOST=your-server.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=serveloco
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_SSL=true
# Leave EMPTY for an encrypted connection without cert verification (simplest — Option A).
# To enable full verification later, download the CA cert to apps/api/certs/ and set:
#   MYSQL_SSL_CA_PATH=./certs/DigiCertGlobalRootG2.crt.pem
MYSQL_SSL_CA_PATH=

# ── MongoDB Atlas (image metadata) ────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=serveloco_images

# ── CORS + public URLs (serveloco.app) ────────────────────────────────
# No wildcards allowed in production. Comma-separated origins.
CORS_ORIGIN=https://admin.serveloco.app,https://app.serveloco.app
PUBLIC_BASE_URL=https://api.serveloco.app

# ── Image storage: S3 ─────────────────────────────────────────────────
STORAGE_DRIVER=s3
S3_BUCKET=villkro-images-prod
S3_REGION=ap-south-1
S3_PUBLIC_URL=https://villkro-images-prod.s3.ap-south-1.amazonaws.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy disk-upload settings (unused when STORAGE_DRIVER=s3, kept for compatibility)
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
STATIC_UPLOAD_PATH=/uploads

# ── Pool + logging (optional) ─────────────────────────────────────────
MYSQL_POOL_SIZE=30
LOG_LEVEL=info
