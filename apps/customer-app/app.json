{
  "expo": {
    "name": "VillKro",
    "slug": "villkro",
    "version": "1.7.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon/icon.png",
    "splash": {
      "image": "./assets/icon/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon/adaptive-icon-foreground.png",
          "color": "#FF6B35"
        }
      ],
      "expo-audio",
      "expo-asset",
      "./plugins/withAlarmSounds",
      "./plugins/withAlarmPermissions",
      ["@rnmapbox/maps", {}],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "VillKro uses your location on the delivery map and for live rider tracking while you are online.",
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VillKro uses your location to pin your delivery address and show your position on the rider delivery map.",
        "NSPhotoLibraryUsageDescription": "VillKro lets admins choose product photos from the library.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "bundleIdentifier": "com.yashsiwach.villkro"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_FULL_SCREEN_INTENT",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE"
      ],
      "package": "com.yashsiwach.villkro",
      "versionCode": 29,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/icon/adaptive-icon-background.png",
        "monochromeImage": "./assets/icon/adaptive-icon-foreground.png"
      }
    },
    "extra": {
      "eas": {
        "projectId": "1df5a9bf-de34-48ea-96f4-68f598d7d318"
      }
    },
    "owner": "yashsiwch",
    "runtimeVersion": "1.6.0",
    "updates": {
      "url": "https://u.expo.dev/1df5a9bf-de34-48ea-96f4-68f598d7d318"
    }
  }
}
